def open_todos() -> list[str] | None:
    text = read_text(MVP_TODO)
    if not text:
        return None
    todos: list[str] = []
    for line in text.splitlines():
        if line.startswith("- [ ]"):
            todos.append(line.replace("- [ ]", "", 1).strip())
    return todos


def command_loop(assume_yes: bool = False, print_only: bool = False) -> int:
    todos = open_todos()
    if todos is None:
        print("docs/mvp-todo.md를 찾을 수 없습니다.")
        return 1
    if not todos:
        print("열린 todo가 없습니다. MVP 완료 조건을 확인하세요.")
        return 0

    print("TARS loop")
    print("\n열린 todo:")
    for index, todo in enumerate(todos[:5], start=1):
        print(f"{index}. {todo}")
    if len(todos) > 5:
        print(f"...외 {len(todos) - 5}개")

    print("\n다음 작업:")
    print(f"- {todos[0]}")

    if print_only or assume_yes:
        print("\nCodex에게 전달할 루프 지시:\n")
        print(build_loop_prompt(todos[0]))
        return 0

    if not sys.stdin.isatty():
        print("\n비대화형 환경이라 확인 입력을 받을 수 없습니다.")
        print("루프 지시를 출력하려면 `tars loop --print`를 사용하세요.")
        return 0

    try:
        answer = input("\n이 작업을 시작할까요? [y/N] ").strip().lower()
    except EOFError:
        print("\n확인 입력을 받지 못해 중단했습니다.")
        print("루프 지시를 출력하려면 `tars loop --print`를 사용하세요.")
        return 0

    if answer not in {"y", "yes"}:
        print("중단했습니다.")
        return 0

    print("\nCodex에게 전달할 루프 지시:\n")
    print(build_loop_prompt(todos[0]))
    return 0


def inbox_sources() -> list[str] | None:
    inbox = DOCS / "inbox"
    if not inbox.exists():
        return None
    sources: list[str] = []
    for path in sorted(inbox.rglob("*")):
        if path.is_file() and path.name != ".gitkeep":
            sources.append(str(path.relative_to(ROOT)))
    return sources


