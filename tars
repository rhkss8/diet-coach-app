    if not prompt:
        print("서비스 정의가 아직 비어 있습니다. 먼저 tars init 을 실행하세요.")
        return 1
    write_text(START_SESSION, "# Start Session Prompt\n\n" + prompt)
    print(prompt)
    return 0


