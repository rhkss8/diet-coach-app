def main(argv: list[str]) -> int:
    if len(argv) == 1 or argv[1] in {"--help", "-h", "help"}:
        print(HELP)
        return 0
    if argv[1] == "--version":
        print(VERSION)
        return 0

    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("command")
    parser.add_argument("--force", action="store_true")
    parser.add_argument("--hard", action="store_true")
    parser.add_argument("--print", action="store_true", dest="print_only")
    parser.add_argument("--yes", "-y", action="store_true")
    args, extra = parser.parse_known_args(argv[1:])

    if extra:
        print(f"알 수 없는 인자: {' '.join(extra)}")
        print("도움말은 tars --help")
        return 2
    if args.hard and args.command != "maintain":
        print("--hard는 tars maintain에서만 사용할 수 있습니다.")
        print("예: tars maintain --hard")
        return 2
    if args.print_only and args.command != "loop":
        print("--print는 tars loop에서만 사용할 수 있습니다.")
        print("예: tars loop --print")
        return 2
    if args.yes and args.command != "loop":
        print("--yes는 tars loop에서만 사용할 수 있습니다.")
        print("예: tars loop --yes")
        return 2

    if args.command == "init":
        return command_init(force=args.force)
    if args.command == "start":
        return command_start()
    if args.command == "prompt":
        return command_prompt()
    if args.command == "maintain":
        return command_maintain(hard=args.hard)
    if args.command == "think":
        return command_think()
    if args.command == "verify":
        return command_verify()
    if args.command == "loop":
        return command_loop(assume_yes=args.yes, print_only=args.print_only)
    if args.command == "wiki":
        return command_wiki()
    if args.command == "acceptance":
        return command_acceptance()
    if args.command == "status":
        return command_status()
    if args.command == "next":
        return command_next()
    if args.command == "doctor":
        return command_doctor()
    if args.command == "done":
        return command_done()
    if args.command == "handoff":
        return command_handoff()

    print(f"알 수 없는 명령: {args.command}")
    print("도움말은 tars --help")
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
