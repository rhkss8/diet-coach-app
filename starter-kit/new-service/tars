def command_done() -> int:
    print("TARS done")
    verify_result = command_verify()
    status = run_git(["status", "--short"]) or "(clean)"

    print(f"- project: {ROOT}")
    print(f"- next todo after commit: {next_todo_line()}")
    print("\nCurrent git status:")
    print(status)
    if verify_result != 0:
        print("\n검증이 실패했습니다. 실패 원인을 수정한 뒤 다시 `tars done`을 실행하세요.")
        return verify_result
    print("\nCommit this slice:")
    print("git add .")
    print('git commit -m "Complete current TARS slice"')
    print("\nThen continue:")
    print("tars next")
    return 0


def command_verify() -> int:
    checks = [
        ("typecheck", "pnpm typecheck"),
        ("lint", "pnpm lint"),
        ("test", "pnpm test"),
        ("format:check", "pnpm format:check"),
    ]

    print("TARS verify")
    failures = 0
    for label, command in checks:
        print(f"\n[{label}] {command}")
        result = subprocess.run(
            ["zsh", "-lc", f"source ~/.zshrc >/dev/null 2>&1; {command}"],
            cwd=ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
        )
        output = result.stdout.strip()
        if result.returncode == 0:
            print("PASS")
        else:
            failures += 1
            print("FAIL")
            if output:
                print("\n".join(output.splitlines()[-40:]))

    if failures:
        print(f"\nVerification failed: {failures} check(s) failed.")
        return 1
    print("\nVerification passed.")
    return 0


