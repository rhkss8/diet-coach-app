        print("\nSuggested command:")
        print("tars loop")
        return 0
    print("열린 todo가 없습니다. MVP 완료 조건을 확인하세요.")
    return 0


def open_todos() -> list[str] | None:
    text = read_text(MVP_TODO)
    if not text:
        return None
    todos: list[str] = []
    for line in text.splitlines():
        if line.startswith("- [ ]"):
            todos.append(line.replace("- [ ]", "", 1).strip())
    return todos


def command_loop() -> int:
    todos = open_todos()
    if todos is None:
        print("docs/mvp-todo.md를 찾을 수 없습니다.")
        return 1
    if not todos:
        print("열린 todo가 없습니다. MVP 완료 조건을 확인하세요.")
        return 0

    print("TARS loop")
    print("\n열린 todo:")
    for index, todo in enumerate(todos[:5], start=1):
        print(f"{index}. {todo}")
    if len(todos) > 5:
        print(f"...외 {len(todos) - 5}개")

    print("\n다음 작업:")
    print(f"- {todos[0]}")
    answer = input("\n이 작업을 시작할까요? [y/N] ").strip().lower()
    if answer not in {"y", "yes"}:
        print("중단했습니다.")
        return 0

    print("\nCodex에게 전달할 루프 지시:\n")
    print(build_loop_prompt(todos[0]))
    return 0


