def run_git(args: list[str]) -> str:
    try:
        result = subprocess.run(
            ["git", *args],
            cwd=ROOT,
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
        )
    except FileNotFoundError:
        return ""
    return result.stdout.strip()


def next_todo_line() -> str:
    text = read_text(MVP_TODO)
    if not text:
        return "docs/mvp-todo.md not found"
    for line in text.splitlines():
        if line.startswith("- [ ]"):
            return line.replace("- [ ]", "-", 1)
    return "No open todo found"


def command_handoff() -> int:
    branch = run_git(["branch", "--show-current"]) or "(not a git repo)"
    status = run_git(["status", "--short"]) or "(clean)"
    remote = run_git(["remote", "-v"]) or "(no remote configured)"

    print("TARS handoff")
    print(f"- project: {ROOT}")
    print(f"- branch: {branch}")
    print(f"- next todo: {next_todo_line()}")
    print("\nGit status:")
    print(status)
    print("\nGit remote:")
    print(remote)
