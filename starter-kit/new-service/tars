def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8") if path.exists() else ""


def write_text(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text, encoding="utf-8")


def is_placeholder_value(value: str) -> bool:
    stripped = value.strip()
    return not stripped or stripped.startswith("[") or stripped.startswith("`[")


def extract_section(markdown: str, heading: str) -> str:
    pattern = rf"^## {re.escape(heading)}\n(?P<body>.*?)(?=^## |\Z)"
    match = re.search(pattern, markdown, flags=re.MULTILINE | re.DOTALL)
    if not match:
        return ""
    body = match.group("body").strip().replace("`", "").strip()
    lines = [line.strip("- ").strip() for line in body.splitlines() if line.strip()]
    return " ".join(lines).strip()


def load_service_definition() -> dict[str, str]:
    markdown = read_text(SERVICE_DEFINITION)
    return {
        "definition": extract_section(markdown, "One-Line Definition"),
        "persona": extract_section(markdown, "Persona"),
        "pain": extract_section(markdown, "Core Pain"),
        "transformation": extract_section(markdown, "Desired Transformation"),
        "mechanism": extract_section(markdown, "Core Mechanism"),
    }


def has_service_definition() -> bool:
    values = load_service_definition()
    required = ["definition", "persona", "pain", "transformation"]
    return all(not is_placeholder_value(values.get(key, "")) for key in required)


def ask(label: str, hint: str = "") -> str:
    print(f"\n{label}")
    if hint:
        print(f"  {hint}")
    while True:
        value = input("> ").strip()
        if value:
            return value
        print("값을 입력해주세요.")


def build_service_definition(values: dict[str, str]) -> str:
    return f"""# Service Definition

## One-Line Definition
{values["definition"]}

## Persona
{values["persona"]}

## Core Pain
{values["pain"]}

## Desired Transformation
Before:
- {values["before"]}

After:
- {values["after"]}

## Core Mechanism
{values["mechanism"]}
"""


