def command_doctor() -> int:
    missing = [filename for filename in required_files() if not (DOCS / filename).exists()]
    missing_paths = [
        path
        for path in [
            ".codex/skills/tars-maintenance/SKILL.md",
            "script/build_and_run.sh",
            "package.json",
        ]
        if not (ROOT / path).exists()
    ]
    if missing:
        print("Doctor: missing required starter files")
        for filename in missing:
            print(f"- docs/{filename}")
    if missing_paths:
        print("Doctor: missing required project files")
        for path in missing_paths:
            print(f"- {path}")
    package = read_text(ROOT / "package.json")
    missing_scripts = [
        script
        for script in ["typecheck", "lint", "test", "format:check"]
        if f'"{script}"' not in package
    ]
    if missing_scripts:
        print("Doctor: missing package scripts")
        for script in missing_scripts:
            print(f"- {script}")
    if missing or missing_paths or missing_scripts:
        return 1

    print("Doctor: ok")
    print(f"- root: {ROOT}")
    print(f"- docs: {DOCS}")
    print(f"- service definition: {'ready' if has_service_definition() else 'needs input'}")
    print("- maintenance skill: ready")
    print("- verification scripts: ready")
