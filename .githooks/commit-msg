#!/usr/bin/env zsh
set -euo pipefail

message_file="$1"
subject="$(sed -n '1p' "$message_file")"

if [[ "$subject" =~ ^(Merge|Revert) ]]; then
  exit 0
fi

allowed_types="feat|fix|docs|style|refactor|test|chore|perf|build|ci|revert"

if [[ ! "$subject" =~ ^(${allowed_types})(\([a-zA-Z0-9._-]+\))?:\ .+ ]]; then
  cat <<'EOF'
커밋 메시지 형식이 맞지 않습니다.

형식:
  fix: 한글 설명
  feat: 한글 설명
  docs: 한글 설명

허용 타입:
  feat, fix, docs, style, refactor, test, chore, perf, build, ci, revert
EOF
  exit 1
fi

if [[ ! "$subject" =~ [가-힣] ]]; then
  cat <<'EOF'
커밋 메시지 제목에는 한글 설명을 포함해야 합니다.

예:
  fix: 로그인 뒤로가기 수정
EOF
  exit 1
fi
